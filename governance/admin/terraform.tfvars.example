# ===============================================================
# 🚀 GCP Foundation: 初期設定シート (Adminプロジェクト用)
# ===============================================================

# ---------------------------------------------------------------
# 1. 【必須】あなたの GCP 環境に合わせて書き換えてください
# ---------------------------------------------------------------

# [重要] あなたが決めたプロジェクトID (例: "my-gcp-admin-9988")
project_id = "your-admin-project-id"

# 請求先アカウントID (例: "012345-6789AB-CDEF01")
billing_account_id = "your-billing-account-id"

# あなたの組織ID (例: "123456789012")
org_id = "your-org-id"

# 作成するアプリケーションのベース名 (例: "my-app")
# この名前を元にプロジェクトIDが生成されます。
app_base_name = "sample-app"

# 環境名 (管理用なので "admin" でOK)
env = "admin"

# ---------------------------------------------------------------
# 2. 【必須】GitHub 連携の設定
# ---------------------------------------------------------------

# あなたの GitHub ユーザー名 または 組織名
gh_org_name = "your-github-org"

# 管理リポジトリ名
gh_repo_name = "your-repo-name"

# アクセスを許可するリポジトリ名のリスト (WIF連携に必要)
# 例: ["my-repo-name"]
allowed_gh_repositories = ["your-repo-name"]

# 💡 ヒント:
# フォルダ ID (infrastructure_folder_id 等) は、scripts/bootstrap.sh を実行すると
# クラウド上のメタデータとして自動保存され、Terraform 側で自動解決されます。

# ---------------------------------------------------------------
# 3. 【選択】セキュリティ & 統制レベル
# ---------------------------------------------------------------

# [ security_level ]
# "standard" : 自由度が高く、学習や検証に最適
# "high"     : 組織ポリシーで強力に制限 (外部IP禁止など)
security_level = "standard"

# ---------------------------------------------------------------
# 4. 監視 & アラート設定
# ---------------------------------------------------------------

# [死活監視 (Uptime Checks)]
# 監視したいサービスの名称とホスト名を指定します。
# 5分間隔で外勤チェックが行われ、異常時は Slack に通知されます。
monitoring_targets = {
  # "my-service" = "your-service-url.a.run.app"
}

# [アラート通知先 Slack チャンネル名]
monitoring_slack_channel = ""

# [定期セキュリティ監査のスケジュール (Cron形式)]
# デフォルトは毎週月曜 9:00 ("0 9 * * 1") です。
# 毎日実行したい場合は "0 9 * * *" と指定してください。
# audit_schedule = "0 9 * * 1"

# ---------------------------------------------------------------
# 5. その他の基本設定 (お好みで)
# ---------------------------------------------------------------

# リージョン (東京: "asia-northeast1", 大阪: "asia-northeast2")
region = "asia-northeast1"

# 予算アラートを飛ばす金額 (日本円)
budget_amount = 50000

# サンドボックスプロジェクトの一律予算額（日本円）
sandbox_budget_amount = 5000

# 基盤管理者のメールアドレス (ラベルとして付与)
admin_group_email = "admin@example.com"

# プロジェクトの責任者名 (ラベルとして付与)
project_owner = "infra-team"

# 予算アラートのPub/Sub通知を有効にするか (推奨: true)
enable_budget_pubsub = true
