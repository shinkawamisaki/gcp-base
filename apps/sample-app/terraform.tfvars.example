# ==============================================================================
# GCP Foundation: 環境設定ファイル (Example)
# 
# [使い方]
# 1. このファイルを `terraform.tfvars` にコピーしてください。
#    cp terraform.tfvars.example terraform.tfvars
# 2. 以下（特に「1.」）の各値を、自身の環境に合わせて書き換えてください。
# ==============================================================================

# 1. 会社・プロジェクト固有のID (必須)
# ------------------------------------------------------------------------------
# [重要] 既存のGCPプロジェクトではなく、本ツールが新規作成するプロジェクトのIDを指定します。
# 例: "my-company-admin-489106"
project_id         = "YOUR_ADMIN_PROJECT_ID"

# [重要] GCP組織ID。GCPコンソールの「IAMと管理 > リソースの管理」から確認できます。
org_id             = "YOUR_ORG_ID"

# [重要] 請求先アカウントID。GCPコンソールの「お支払い」から確認できます。
# 形式: "0XXXXX-XXXXXX-XXXXXX"
billing_account_id = "YOUR_BILLING_ACCOUNT_ID"

# 2. 環境設定
# ------------------------------------------------------------------------------
# 環境名 (prd/stg/dev 等)
env                = "prd"

# デプロイ先のリージョン
region             = "asia-northeast1"

# 組織レベルの機能（SCC通知や組織全体のログ集約）を使用するかどうか
# 初心者はまずは true でOKですが、組織管理者権限がない場合は false にしてください。
use_org_level      = true

# 3. 予算・運用ルール
# ------------------------------------------------------------------------------
# 月額予算の上限 (円単位)。これを超えると通知が飛びます。
budget_amount      = 50000
currency           = "JPY"

# ログの保存日数
log_retention_days = 365

# 4. 新規プロジェクト払い出し設定
# ------------------------------------------------------------------------------
# 今後作成するアプリ用プロジェクトのベース名
app_base_name      = "my-app"

# 5. GitHub Actions 連携設定 (WIF)
# ------------------------------------------------------------------------------
# あなたの GitHub ユーザー名 または 組織名 (例: "my-username")
gh_org_name    = "YOUR_GH_ORG_OR_USER"

# 管理者のメールアドレス (通知などの送付先)
admin_group_email  = "admin@example.com"

# 許可する GitHub リポジトリのリスト (ここに登録したリポジトリからのみ GCP 操作が可能になります)
allowed_gh_repositories = [
  "gcp-foundation",
  "my-app-repo"
]
