# ==============================================================================
# GCP Foundation: .gitignore (Professional Standard)
# ==============================================================================

# --- Terraform ---
# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Ignore backend config files
**/backend.hcl

# Exclude all .tfvars files, which are likely to contain sensitive data, such as
# password, private keys, and other secrets. These should not be part of version 
# control as they are data based.
*.tfvars
*.tfvars.json

# Allow parameter example files
!terraform.tfvars.example

# Ignore override files as they may contain local-specific configurations
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Include override files for specific environments
!environments/**/override.tf

# Ignore .terraformrc and terraform.rc
.terraformrc
terraform.rc

# --- Python (Billing Notifier) ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
.env
.venv
venv/
ENV/
env/
.pytest_cache/
.coverage
htmlcov/

# --- macOS (OS X) ---
.DS_Store
.AppleDouble
.LSOverride
Icon
Network Trash Folder
Temporary Items
.apdisk

# --- Editors / IDEs ---
# JetBrains (IntelliJ, PyCharm, etc.)
.idea/
*.iws
*.iml
*.ipr

# Visual Studio Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.history/
*.code-workspace

# Vim / Emacs
*~
*.swp
*.swo
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
confidential/

# --- Sensitive Information (Safety Net) ---
*.pem
*.key
*.pub
secret.txt
credentials.json
# --- End of .gitignore ---
